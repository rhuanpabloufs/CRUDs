{
  $jsonSchema: {
    bsonType: "object",
    required: [
      "nome",
      "grau",
      "turno",
      "campus",
      "nivel"
    ],
    properties: {
      nome: {
        bsonType: "string",
        maxLength: 100
      },
      grau: {
        bsonType: [
          "string",
          "null"
        ],
        enum: [
          "Bacharelado",
          "Licenciatura Plena",
          null
        ]
      },
      nivel: {
        bsonType: "string",
        enum: [
          "Graduação",
          "Mestrado",
          "Doutorado",
          "Lato"
        ]
      },
      campus: {
        bsonType: [
          "string",
          "null"
        ],
        maxLength: 100
      },
      turno: {
        bsonType: "string",
        enum: [
          "Matutino",
          "Vespertino",
          "Noturno",
          "Turno Indefinido"
        ]
      }
    }
  }
}